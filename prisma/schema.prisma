generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum ParticipantStatus {
  POTENTIAL
  ACTIVE
}

enum BriefType {
  POTENTIAL
  ACTIVE
  MODERATOR
  REPORT
}

enum SyncStatus {
  SUCCESS
  FAILED
}

enum PreparationEventStatus {
  UPCOMING
  PAST
  CANCELED
  UNKNOWN
}

enum EventParticipantKind {
  POTENTIAL
  ACTIVE
}

enum EventParticipantStatus {
  INVITED
  CONFIRMED
  REFUSED
  ATTENDED
  MISSED
  UNKNOWN
}

enum ActiveParticipantDecision {
  INVITED_ATTENDED
  INVITED_REFUSED
  DECLINED_BY_US
}

model Participant {
  id               String            @id @default(cuid())
  bitrixDealId     String?           @unique
  bitrixContactId  String?           @unique
  status           ParticipantStatus @default(POTENTIAL)
  fullName         String
  email            String?
  phone            String?
  telegram         String?
  company          String?
  position         String?
  city             String?
  sourceFormatSlug String?
  sourcePayload    Json?
  lastSyncedAt     DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  eventParticipants EventParticipant[]
  visits           Visit[]
  matchRuns        MatchRun[]
  briefs           Brief[]
}

model EventFormat {
  slug           String   @id
  name           String
  description    String
  audience       String?
  moderatorNotes String?
  bitrixEventTypeIds String[] @default([])
  bitrixSyncTitleQuery String @default("")
  matchingRules  Json?
  promptPotential String   @default("")
  promptActive   String   @default("")
  promptModerator String   @default("")
  promptReport   String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  events         Event[]
  visits         Visit[]
  briefs         Brief[]
}

model Event {
  id            String      @id @default(cuid())
  title         String
  startsAt      DateTime?
  endsAt        DateTime?
  status        PreparationEventStatus @default(UNKNOWN)
  bitrixEventId String?
  bitrixSmartItemId String? @unique
  bitrixEventTypeId String?
  bitrixEventTypeLabel String?
  formatSlug    String
  format        EventFormat @relation(fields: [formatSlug], references: [slug])
  sourcePayload  Json?
  syncedAt      DateTime?
  participants  EventParticipant[]
  matchRuns     EventMatchRun[]
  briefs        Brief[]
  visits        Visit[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model EventParticipant {
  id              String                 @id @default(cuid())
  eventId         String
  event           Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participantId   String?
  participant     Participant?           @relation(fields: [participantId], references: [id], onDelete: SetNull)
  kind            EventParticipantKind   @default(POTENTIAL)
  status          EventParticipantStatus @default(UNKNOWN)
  bitrixVisitId   String?
  bitrixDealId    String?
  bitrixContactId String?
  fullName        String
  email           String?
  phone           String?
  telegram        String?
  company         String?
  position        String?
  city            String?
  age             Int?
  gender          String?
  businessMain    String?
  businessExtra1  String?
  businessExtra2  String?
  businessExtra3  String?
  businessProfile Json?
  enrichment      Json?
  matchedScore    Float?
  matchRationale  String?
  attendanceMarked Boolean                @default(false)
  activeDecision  ActiveParticipantDecision?
  activeDecisionComment String?
  sourcePayload   Json?
  statusUpdatedAt DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  briefs          Brief[]

  @@unique([eventId, bitrixVisitId])
  @@unique([eventId, bitrixDealId])
  @@index([eventId, status])
  @@index([bitrixDealId])
  @@index([bitrixContactId])
}

model Visit {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  eventId       String?
  event         Event?      @relation(fields: [eventId], references: [id])
  formatSlug    String
  format        EventFormat @relation(fields: [formatSlug], references: [slug])
  attendedAt    DateTime
  role          String      @default("guest")
  notes         String?
  createdAt     DateTime    @default(now())
}

model MatchRun {
  id                   String      @id @default(cuid())
  participantId        String
  participant          Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  score                Float?
  activeParticipantIds String[]
  rationale            String?
  suggestedFormatSlugs String[]
  requestPayload       Json?
  responsePayload      Json?
  error                String?
  createdAt            DateTime    @default(now())
}

model EventMatchRun {
  id                     String   @id @default(cuid())
  eventId                String
  event                  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activeParticipantIds   String[] @default([])
  activeParticipantCount Int      @default(0)
  rationale              String?
  requestPayload         Json?
  responsePayload        Json?
  error                  String?
  createdAt              DateTime @default(now())
}

model Brief {
  id            String       @id @default(cuid())
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id], onDelete: Cascade)
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventParticipantId String?
  eventParticipant   EventParticipant? @relation(fields: [eventParticipantId], references: [id], onDelete: Cascade)
  briefType     BriefType
  formatSlug    String?
  format        EventFormat? @relation(fields: [formatSlug], references: [slug])
  model         String
  prompt        String
  content       Json
  rawContent    String?
  version       Int          @default(1)
  createdByRole Role
  createdAt     DateTime     @default(now())
}

model AppUser {
  id           String   @id @default(cuid())
  login        String   @unique
  displayName  String
  role         Role     @default(VIEWER)
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SyncLog {
  id           String     @id @default(cuid())
  source       String
  status       SyncStatus
  bitrixDealId String?
  message      String?
  payload      Json?
  createdAt    DateTime   @default(now())
}

model AutoSyncLock {
  key       String   @id
  owner     String
  lockedAt  DateTime
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BitrixAutoSyncCursor {
  query        String   @id
  lastSyncedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Club {
  id        String   @id            // = Profile workspace_id, e.g. "ws_cf1"
  name      String
  createdAt DateTime @default(now())
  rules            ActiveRule[]
  roles            ActiveRole[]
  formatReadiness  FormatReadiness[]
  notes            ParticipantNote[]
  members          MemberProfile[]
}

model MemberProfile {
  id            String    @id @default(cuid())
  clubId        String
  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  profileId     String
  displayName   String?
  stateCode     String?
  tenureYear    Int?
  paymentPhase  String?
  businessBand  Int?
  retention     Int?
  attendance    Int?
  dossier       Json
  participation Json
  profileUpdatedAt DateTime?
  syncedAt      DateTime  @updatedAt
  @@unique([clubId, profileId])
}

enum ActiveRuleType {
  MIN_YEAR
  MIN_PERCENT
  PHASE
  MIN_BAND
  HAS_ROLE
}

model ActiveRule {
  id          String         @id @default(cuid())
  clubId      String
  club        Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  key         String
  label       String
  description String?
  type        ActiveRuleType
  factKey     String?
  config      Json
  enabled     Boolean        @default(true)
  optional    Boolean        @default(false)
  sortOrder   Int            @default(0)
  @@unique([clubId, key])
}

model ActiveRole {
  id          String                 @id @default(cuid())
  clubId      String
  club        Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name        String
  description String?
  assignments ActiveRoleAssignment[]
  @@unique([clubId, name])
}

model ActiveRoleAssignment {
  id        String     @id @default(cuid())
  roleId    String
  role      ActiveRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  profileId String
  @@unique([roleId, profileId])
}

enum ReadinessState {
  READY
  NOT_READY
  UNMARKED
}

model FormatReadiness {
  id        String         @id @default(cuid())
  clubId    String
  club      Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  profileId String
  formatId  String
  readiness ReadinessState @default(UNMARKED)
  updatedAt DateTime       @updatedAt
  @@unique([profileId, formatId])
}

model ParticipantNote {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  profileId String   @unique
  note      String
  updatedAt DateTime @updatedAt
}
